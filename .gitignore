.pio/
.pio-core/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch
*.bin
*.elf
*.map
build/

# macOS junk
.DS_Store

# Never commit real secrets — only secrets.example.yaml is tracked.
secrets.yaml
**/secrets.yaml
!**/secrets.example.yaml
.env
*.local

.venv/
__pycache__/
*.pyc

# Locally generated by scripts/preview-display.sh — mirrors whatever
# calendar data is live in your HA instance, so it must never be committed.
/preview.html
.preview-data.json

# Claude Code's local session config — can accumulate real credentials
# (e.g. long-lived API tokens) in its permissions allowlist. Never commit.
.claude/
